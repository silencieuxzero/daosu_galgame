{
  "manifest_version": 2,
  "version": "1.0.0",
  "name": "视觉小说插件",
  "description": "模块化的文字类视觉小说插件，支持角色互动、好感度系统、存档管理、线索收集与记事本等功能",
  "author": {
    "name": "DaoSu VisualNovel Team",
    "url": "https://github.com/daosu/visual-novel"
  },
  "license": "GPL-v3.0-or-later",
  "urls": {
    "repository": "https://github.com/daosu/visual-novel",
    "homepage": "https://github.com/daosu/visual-novel",
    "documentation": "https://github.com/daosu/visual-novel",
    "issues": "https://github.com/daosu/visual-novel/issues"
  },
  "changelog": "CHANGELOG.md",
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.0.0"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [],
  "capabilities": [
    "send.text",
    "config.get"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "locales_path": "_locales",
    "supported_locales": [
      "zh-CN"
    ]
  },
  "id": "com.daosu.visual-novel"
}
